---
const whatsappNumber = '51953869245';
const whatsappMsg = encodeURIComponent('Hola Dr. Rolando, me gustaría coordinar una consulta legal.');
const whatsappURL = `https://wa.me/${whatsappNumber}?text=${whatsappMsg}`;
---

<!-- Franja visual antes de contacto -->
<div class="relative h-48 sm:h-64 lg:h-72 overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-center bg-fixed"
    style="background-image: url('/oficina-despacho.png')"
  ></div>
  <div class="absolute inset-0 bg-black/40"></div>
  <div class="relative z-10 h-full flex items-center justify-center">
    <p class="reveal text-white text-lg sm:text-2xl font-light tracking-wide text-center px-6" style="font-family: var(--font-serif)">
      "La mejor defensa comienza con una buena consulta"
    </p>
  </div>
</div>

<section id="contacto" class="py-20 lg:py-28 bg-surface">
  <div class="max-w-5xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">

      <!-- Info -->
      <div>
        <div class="reveal">
          <p class="text-xs font-medium tracking-widest text-text-muted uppercase mb-3">Contacto</p>
          <h2 class="text-3xl sm:text-4xl font-light text-text mb-6 leading-snug">
            ¿Necesita <span class="font-medium">asesoría legal</span>?
          </h2>
        </div>

        <p class="reveal reveal-delay-1 text-text-muted leading-relaxed mb-8">
          Escríbanos para coordinar una consulta. Respondemos dentro de las 24 horas hábiles.
        </p>

        <!-- Email -->
        <div class="reveal reveal-delay-2 flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-full bg-blue/10 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <a href="mailto:consultas@mlpperu.com" class="text-blue hover:text-blue-dark transition-colors duration-200 text-sm font-medium">
            consultas@mlpperu.com
          </a>
        </div>

        <!-- WhatsApp -->
        <div class="reveal reveal-delay-3 flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-full bg-[#25D366]/10 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4" fill="#25D366" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <a href={whatsappURL} target="_blank" rel="noopener noreferrer" class="text-[#25D366] hover:opacity-80 transition-opacity duration-200 text-sm font-medium">
            WhatsApp — +51 953 869 245
          </a>
        </div>

        <!-- LinkedIn -->
        <div class="reveal reveal-delay-4 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-[#0A66C2]/10 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4" fill="#0A66C2" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <a
            href="https://www.linkedin.com/in/rolando-zagret-risco-valera-6024731aa/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#0A66C2] hover:opacity-80 transition-opacity duration-200 text-sm font-medium"
          >
            LinkedIn — Dr. Rolando Zagret
          </a>
        </div>
      </div>

      <!-- Formulario simple -->
      <div class="reveal reveal-delay-2 bg-white rounded-xl p-7 border border-[#E8E6E0]">
        <form
          action="mailto:consultas@mlpperu.com"
          method="get"
          enctype="text/plain"
          class="space-y-4"
        >
          <div>
            <label for="contact-name" class="block text-xs font-medium text-text-muted uppercase tracking-wide mb-1.5">Nombre</label>
            <input
              id="contact-name"
              type="text"
              name="name"
              placeholder="Su nombre completo"
              class="w-full px-4 py-2.5 text-sm border border-[#E8E6E0] rounded-md bg-cream text-text placeholder:text-[#B0AFAA] focus:outline-none focus:border-blue transition-colors duration-200"
              required
            />
          </div>
          <div>
            <label for="contact-email" class="block text-xs font-medium text-text-muted uppercase tracking-wide mb-1.5">Correo electrónico</label>
            <input
              id="contact-email"
              type="email"
              name="email"
              placeholder="correo@ejemplo.com"
              class="w-full px-4 py-2.5 text-sm border border-[#E8E6E0] rounded-md bg-cream text-text placeholder:text-[#B0AFAA] focus:outline-none focus:border-blue transition-colors duration-200"
              required
            />
          </div>
          <div>
            <label for="contact-message" class="block text-xs font-medium text-text-muted uppercase tracking-wide mb-1.5">Consulta</label>
            <textarea
              id="contact-message"
              name="body"
              placeholder="Describa brevemente su situación legal..."
              rows="4"
              class="w-full px-4 py-2.5 text-sm border border-[#E8E6E0] rounded-md bg-cream text-text placeholder:text-[#B0AFAA] focus:outline-none focus:border-blue transition-colors duration-200 resize-none"
              required
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3 bg-blue text-white text-sm font-medium rounded-md hover:bg-blue-dark transition-colors duration-200"
          >
            Enviar consulta
          </button>
        </form>
        <p class="mt-3 text-xs text-[#B0AFAA] text-center">Al enviar acepta que nos contactemos por correo.</p>
      </div>

    </div>
  </div>
</section>
