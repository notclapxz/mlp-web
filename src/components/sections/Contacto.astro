---
---

<section id="contacto" class="py-20 lg:py-28 bg-[#F3F2EF]">
  <div class="max-w-5xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">

      <!-- Info -->
      <div>
        <div class="reveal">
          <p class="text-xs font-medium tracking-widest text-[#5A6478] uppercase mb-3">Contacto</p>
          <h2 class="text-3xl sm:text-4xl font-light text-[#1A1A2E] mb-6 leading-snug">
            ¿Necesita <span class="font-medium">asesoría legal</span>?
          </h2>
        </div>

        <p class="reveal reveal-delay-1 text-[#5A6478] leading-relaxed mb-8">
          Escríbanos para coordinar una consulta. Respondemos dentro de las 24 horas hábiles.
        </p>

        <div class="reveal reveal-delay-2 flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-[#2B6CB0]/10 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-[#2B6CB0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <a
            href="mailto:consultas@mlpperu.com"
            class="text-[#2B6CB0] hover:text-[#1E4E8C] transition-colors duration-200 text-sm font-medium"
          >
            consultas@mlpperu.com
          </a>
        </div>
      </div>

      <!-- Formulario simple -->
      <div class="reveal reveal-delay-2 bg-white rounded-xl p-7 border border-[#E8E6E0]">
        <form
          action={`mailto:consultas@mlpperu.com`}
          method="get"
          enctype="text/plain"
          class="space-y-4"
        >
          <div>
            <label class="block text-xs font-medium text-[#5A6478] uppercase tracking-wide mb-1.5">Nombre</label>
            <input
              type="text"
              name="name"
              placeholder="Su nombre completo"
              class="w-full px-4 py-2.5 text-sm border border-[#E8E6E0] rounded-md bg-[#FAFAF8] text-[#1A1A2E] placeholder:text-[#B0AFAA] focus:outline-none focus:border-[#2B6CB0] transition-colors duration-200"
              required
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#5A6478] uppercase tracking-wide mb-1.5">Correo electrónico</label>
            <input
              type="email"
              name="email"
              placeholder="correo@ejemplo.com"
              class="w-full px-4 py-2.5 text-sm border border-[#E8E6E0] rounded-md bg-[#FAFAF8] text-[#1A1A2E] placeholder:text-[#B0AFAA] focus:outline-none focus:border-[#2B6CB0] transition-colors duration-200"
              required
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-[#5A6478] uppercase tracking-wide mb-1.5">Consulta</label>
            <textarea
              name="body"
              placeholder="Describa brevemente su situación legal..."
              rows="4"
              class="w-full px-4 py-2.5 text-sm border border-[#E8E6E0] rounded-md bg-[#FAFAF8] text-[#1A1A2E] placeholder:text-[#B0AFAA] focus:outline-none focus:border-[#2B6CB0] transition-colors duration-200 resize-none"
              required
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3 bg-[#2B6CB0] text-white text-sm font-medium rounded-md hover:bg-[#1E4E8C] transition-colors duration-200"
          >
            Enviar consulta
          </button>
        </form>
        <p class="mt-3 text-xs text-[#B0AFAA] text-center">Al enviar acepta que nos contactemos por correo.</p>
      </div>

    </div>
  </div>
</section>
