---
---

<section id="inicio" class="min-h-screen flex items-center justify-center pt-16 bg-pattern">
  <div class="max-w-5xl mx-auto px-6 py-20 text-center">

    <!-- Logo MLP -->
    <div class="reveal mb-10 flex justify-center">
      <div class="w-24 h-24 flex items-center justify-center rounded-2xl bg-white shadow-sm border border-[#E8E6E0]">
        <span class="text-4xl font-bold tracking-tight leading-none">
          <span style="color: #E8B84B">M</span><span style="color: #3A7D44">L</span><span style="color: #2B6CB0">P</span>
        </span>
      </div>
    </div>

    <!-- Nombre -->
    <p class="reveal reveal-delay-1 text-sm font-medium tracking-widest text-[#5A6478] uppercase mb-3">
      Media & Legal Planning Chamber
    </p>

    <h1 class="reveal reveal-delay-2 text-4xl sm:text-5xl lg:text-6xl font-light text-[#1A1A2E] leading-tight mb-4">
      Dr. Rolando Zagret<br class="hidden sm:block" />
      <span class="font-medium">Risco Valera</span>
    </h1>

    <p class="reveal reveal-delay-3 text-lg sm:text-xl text-[#5A6478] font-light max-w-xl mx-auto mb-10 leading-relaxed">
      Asesoría legal con experiencia comprobada en derecho penal, civil, laboral y administrativo.
    </p>

    <!-- CTA -->
    <div class="reveal reveal-delay-4 flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a
        href="#contacto"
        class="px-8 py-3.5 bg-[#2B6CB0] text-white rounded-md hover:bg-[#1E4E8C] transition-colors duration-200 text-sm font-medium"
      >
        Solicitar consulta
      </a>
      <a
        href="#servicios"
        class="px-8 py-3.5 text-[#2B6CB0] border border-[#2B6CB0]/40 rounded-md hover:border-[#2B6CB0] hover:bg-[#2B6CB0]/5 transition-colors duration-200 text-sm font-medium"
      >
        Ver servicios
      </a>
    </div>

    <!-- Stats rápidos debajo del CTA -->
    <div class="reveal mt-16 flex flex-wrap justify-center gap-10 border-t border-[#E8E6E0] pt-10">
      <div class="text-center">
        <p class="text-2xl font-light text-[#2B6CB0]">28+</p>
        <p class="text-xs text-[#5A6478] uppercase tracking-wide mt-1">Años de ejercicio</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-light text-[#E8B84B]">116+</p>
        <p class="text-xs text-[#5A6478] uppercase tracking-wide mt-1">Casos gestionados</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-light text-[#3A7D44]">5</p>
        <p class="text-xs text-[#5A6478] uppercase tracking-wide mt-1">Maestrías y posgrados</p>
      </div>
      <div class="text-center">
        <p class="text-2xl font-light text-[#2B6CB0]">4</p>
        <p class="text-xs text-[#5A6478] uppercase tracking-wide mt-1">Áreas de práctica</p>
      </div>
    </div>

  </div>
</section>
