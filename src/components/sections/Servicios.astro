---
const servicios = [
  {
    nombre: 'Derecho Penal',
    descripcion: 'Defensa y representación en procesos penales. Protegemos sus derechos en cada etapa del proceso.',
    acento: '#2B6CB0',
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3L4 7v5c0 5.25 3.5 10.15 8 11.35C16.5 22.15 20 17.25 20 12V7L12 3z"/>
    </svg>`,
  },
  {
    nombre: 'Derecho Civil',
    descripcion: 'Contratos, obligaciones, familia y sucesiones. Asesoría integral en materia civil.',
    acento: '#E8B84B',
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 12h6M9 16h6M9 8h6M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>`,
  },
  {
    nombre: 'Derecho Laboral',
    descripcion: 'Relaciones laborales, despidos, beneficios sociales. Defensa para trabajadores y empresas.',
    acento: '#3A7D44',
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="7" width="20" height="14" rx="2"/>
      <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2M12 12v4M10 14h4"/>
    </svg>`,
  },
  {
    nombre: 'Derecho Administrativo',
    descripcion: 'Procedimientos ante entidades del Estado. Recursos administrativos y contencioso-administrativo.',
    acento: '#2B6CB0',
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3"/>
    </svg>`,
  },
];
---

<section id="servicios" class="py-20 lg:py-28 bg-surface">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="reveal text-center mb-14">
      <p class="text-xs font-medium tracking-widest text-text-muted uppercase mb-3">Áreas de práctica</p>
      <h2 class="text-3xl sm:text-4xl font-light text-text">
        Nuestros <span class="font-medium">servicios</span>
      </h2>
    </div>

    <!-- Layout: Foto + Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">

      <!-- Foto biblioteca -->
      <div class="reveal lg:col-span-5 overflow-hidden rounded-xl shadow-lg">
        <img
          src="/oficina-biblioteca.png"
          alt="Biblioteca del estudio — libros de derecho"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>

      <!-- Grid de servicios -->
      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-5">
        {servicios.map((s, i) => (
          <div class={`reveal reveal-delay-${i + 1} bg-white rounded-xl p-8 border border-[#E8E6E0] hover:shadow-md hover:-translate-y-0.5 transition-all duration-300`}>
            <!-- Icon con color de acento -->
            <div
              class="w-11 h-11 rounded-lg flex items-center justify-center mb-5"
              style={`background-color: ${s.acento}12; color: ${s.acento}`}
              set:html={s.svg}
            />
            <h3 class="text-base font-semibold text-text mb-2 tracking-tight">{s.nombre}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{s.descripcion}</p>
            <div class="mt-6 h-px w-8 rounded-full" style={`background-color: ${s.acento}`}></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
