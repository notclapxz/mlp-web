---
const credenciales = [
  {
    id: '01',
    titulo: 'Título de Abogado',
    inst: 'PUCP',
    year: '1997',
    preview: '/certificados/previews/01-titulo-abogado-pucp.png',
    pdf: '/certificados/Título de Abogado PUCP 31.07.2002.pdf',
    color: '#2B6CB0',
  },
  {
    id: '02',
    titulo: 'Maestría en Ciencias Penales',
    inst: 'UNMSM',
    year: '2006',
    preview: '/certificados/previews/02-maestria-derecho-penal.png',
    pdf: '/certificados/Constancia de Estudios de Maestría en Derecho Penal.pdf',
    color: '#1A1A2E',
  },
  {
    id: '03',
    titulo: 'Master en Gerencia Pública',
    inst: 'EUCIM Business School',
    year: '2018',
    preview: '/certificados/previews/03-master-gerencia-publica.png',
    pdf: '/certificados/Título Propio Master en Gerencia Pública Apostillado.pdf',
    color: '#3A7D44',
  },
  {
    id: '04',
    titulo: 'Máster en Alta Dirección Empresarial',
    inst: 'European Open Business School',
    year: '2021',
    preview: '/certificados/previews/04-master-alta-direccion.png',
    pdf: '/certificados/Máster Alta Dirección Empresarial Universidad de Álcala.pdf',
    color: '#E8B84B',
  },
  {
    id: '05',
    titulo: 'Máster en Política Criminal',
    inst: 'Univ. de Salamanca',
    year: '2025',
    preview: '/certificados/previews/05-master-politica-criminal.png',
    pdf: '/certificados/Diploma Máster en Política Criminal.pdf',
    color: '#2B6CB0',
  },
  {
    id: '06',
    titulo: 'Diploma en Compliance Corporativo',
    inst: 'Instituto para la Calidad — PUCP',
    year: '2021',
    preview: '/certificados/previews/06-diploma-compliance.png',
    pdf: '/certificados/Diploma Compliance Corporativo y Auditoría de Riesgos.pdf',
    color: '#3A7D44',
  },
  {
    id: '07',
    titulo: 'Primer Puesto — Compliance y Auditoría',
    inst: 'Instituto para la Calidad — PUCP',
    year: '2021',
    preview: '/certificados/previews/07-constancia-primer-puesto.png',
    pdf: '/certificados/Constancia Primer Puesto Compliance Corporativo y Auditoría de Riesgos.pdf',
    color: '#E8B84B',
  },
];
---

<section id="nosotros" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="reveal text-center mb-14">
      <p class="text-xs font-medium tracking-widest text-text-muted uppercase mb-3">El estudio</p>
      <h2 class="text-3xl sm:text-4xl font-light text-text">
        Trayectoria y <span class="font-medium">formación</span>
      </h2>
    </div>

    <!-- Foto panorámica de sala de reuniones -->
    <div class="reveal mb-14 overflow-hidden rounded-xl shadow-lg">
      <img
        src="/oficina-reuniones.png"
        alt="Sala de reuniones del estudio — atención a clientes"
        class="w-full h-64 sm:h-80 lg:h-96 object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

      <!-- Foto — columna izquierda (2/5) -->
      <div class="reveal lg:col-span-2 flex flex-col items-center lg:items-start gap-6">
        <!-- Foto circular con ring de acento -->
        <div class="relative">
          <div class="w-48 h-48 lg:w-52 lg:h-52 rounded-full ring-4 ring-blue/15 ring-offset-4 ring-offset-cream overflow-hidden shadow-lg">
            <img
              src="/dr-rolando.jpg"
              alt="Rolando Zagret Risco Valera — Fundador y Socio principal"
              class="w-full h-full object-cover object-top scale-110"
            />
          </div>
          <!-- Badge CAL -->
          <div class="absolute -bottom-2 -right-2 bg-blue text-white text-[10px] font-semibold px-2.5 py-1 rounded-full shadow-md">
            CAL N° 35124
          </div>
        </div>

        <!-- Identidad debajo de la foto -->
        <div class="text-center lg:text-left">
          <p class="font-semibold text-text text-base leading-tight">Rolando Zagret<br/>Risco Valera</p>
          <p class="text-sm text-text-muted mt-1.5">Fundador y Socio principal · San Isidro, Lima</p>
        </div>
      </div>

      <!-- Contenido derecho — columna derecha (3/5) -->
      <div class="lg:col-span-3">

        <p class="reveal text-text-muted leading-relaxed mb-8 text-sm">
          Risco Valera Abogados &amp; Consultores es un estudio jurídico con sede en San Isidro, Lima. Con más de 20 años de ejercicio profesional y más de 15 años bajo la marca MLP, brindamos asesoría legal a personas naturales y empresas con un enfoque directo y orientado a resultados.
        </p>

        <!-- Formación académica — ticker infinito -->
        <div class="reveal reveal-delay-1">
          <!-- Header: label + botón pause/play -->
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-medium tracking-widest text-text-muted uppercase">Formación académica</p>
            <button id="cert-play" class="cert-play-btn" aria-label="Pausar carrusel" title="Pausar">
              <!-- Ícono pause (visible cuando corre) -->
              <svg id="cert-icon-pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
              </svg>
              <!-- Ícono play (visible cuando está pausado) -->
              <svg id="cert-icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none">
                <polygon points="5 3 19 12 5 21 5 3"/>
              </svg>
            </button>
          </div>

          <!-- Ticker wrapper: overflow hidden + mask fade en bordes -->
          <div class="cert-ticker-wrapper">
            <div class="cert-ticker-track" id="cert-track">

              <!-- Set 1: cards reales (accesibles, tabulables) -->
              {credenciales.map((cred) => (
                <button
                  class="cert-card group flex-none w-32 bg-white rounded-lg overflow-hidden shadow-sm border border-black/5 hover:shadow-md transition-shadow duration-200 text-left cursor-pointer"
                  data-pdf={cred.pdf}
                  data-titulo={cred.titulo}
                  title={`${cred.titulo} — ${cred.inst}`}
                >
                  <div class="relative overflow-hidden h-[4.5rem] bg-gray-50">
                    <img
                      src={cred.preview}
                      alt={cred.titulo}
                      class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-2">
                    <p class="text-[10px] font-medium text-text leading-tight line-clamp-2">{cred.titulo}</p>
                    <p class="text-[9px] text-text-muted mt-0.5 leading-tight">{cred.year} · {cred.inst}</p>
                  </div>
                </button>
              ))}

              <!-- Set 2: clones para el loop seamless (aria-hidden, no tabulables) -->
              {credenciales.map((cred) => (
                <button
                  class="cert-card group flex-none w-32 bg-white rounded-lg overflow-hidden shadow-sm border border-black/5 text-left cursor-pointer"
                  data-pdf={cred.pdf}
                  data-titulo={cred.titulo}
                  aria-hidden="true"
                  tabindex="-1"
                >
                  <div class="relative overflow-hidden h-[4.5rem] bg-gray-50">
                    <img
                      src={cred.preview}
                      alt=""
                      class="w-full h-full object-cover object-top"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-2">
                    <p class="text-[10px] font-medium text-text leading-tight line-clamp-2">{cred.titulo}</p>
                    <p class="text-[9px] text-text-muted mt-0.5 leading-tight">{cred.year} · {cred.inst}</p>
                  </div>
                </button>
              ))}

            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Modal PDF viewer -->
<div id="cert-modal" class="cert-modal-backdrop" aria-modal="true" role="dialog" aria-label="Ver certificado">
  <div class="cert-modal-box">
    <!-- Header -->
    <div class="cert-modal-header">
      <p id="cert-modal-title" class="cert-modal-title"></p>
      <button id="cert-modal-close" aria-label="Cerrar" class="cert-modal-close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <!-- iframe PDF -->
    <div class="cert-modal-body">
      <iframe id="cert-modal-iframe" src="" title="Certificado" class="cert-modal-iframe" oncontextmenu="return false;"></iframe>
    </div>
  </div>
</div>

<style>
  /* ── Ticker: wrapper con overflow hidden + fade en bordes ── */
  .cert-ticker-wrapper {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  /* ── Track: flex en línea, animación CSS pura ── */
  .cert-ticker-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    padding: 0.25rem 0 0.75rem;
    animation: cert-scroll 28s linear infinite;
  }


  /* ── Keyframe: mueve exactamente el 50% (= 1 set de 7 cards) ── */
  @keyframes cert-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Botón play/pause ── */
  .cert-play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    background: white;
    color: #5A6478;
    cursor: pointer;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .cert-play-btn:hover {
    background: #f8f8f6;
    border-color: #2B6CB0;
    color: #2B6CB0;
  }

  /* ── Reduced motion: detiene la animación, oculta los clones ── */
  @media (prefers-reduced-motion: reduce) {
    .cert-ticker-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
    }
    .cert-card[aria-hidden="true"] {
      display: none;
    }
    .cert-ticker-wrapper {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  /* ── Modal PDF ── */
  .cert-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .cert-modal-backdrop.open {
    display: flex;
  }
  .cert-modal-box {
    background: white;
    border-radius: 12px;
    width: 100%;
    max-width: 860px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.35);
  }
  .cert-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid #e8e6e0;
    flex-shrink: 0;
  }
  .cert-modal-title {
    font-size: 13px;
    font-weight: 500;
    color: #1A1A2E;
  }
  .cert-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #5A6478;
    cursor: pointer;
    transition: background 0.15s;
  }
  .cert-modal-close:hover {
    background: #f3f2ef;
    color: #1A1A2E;
  }
  .cert-modal-body {
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }
  .cert-modal-iframe {
    width: 100%;
    height: 100%;
    min-height: 70vh;
    border: none;
    display: block;
  }
</style>

<script>
  // ── Ticker: botón play/pause ──
  // Solo el botón controla pause — hover NO pausa
  const track     = document.getElementById('cert-track') as HTMLElement;
  const playBtn   = document.getElementById('cert-play') as HTMLButtonElement;
  const iconPause = document.getElementById('cert-icon-pause') as HTMLElement;
  const iconPlay  = document.getElementById('cert-icon-play') as HTMLElement;

  let paused = false;

  playBtn?.addEventListener('click', () => {
    paused = !paused;
    track.style.animationPlayState = paused ? 'paused' : 'running';
    iconPause.style.display = paused ? 'none' : '';
    iconPlay.style.display  = paused ? '' : 'none';
    playBtn.setAttribute('aria-label', paused ? 'Reanudar carrusel' : 'Pausar carrusel');
    playBtn.setAttribute('title', paused ? 'Reanudar' : 'Pausar');
  });

  // ── Modal PDF ──
  const modal      = document.getElementById('cert-modal') as HTMLElement;
  const iframe     = document.getElementById('cert-modal-iframe') as HTMLIFrameElement;
  const modalTitle = document.getElementById('cert-modal-title') as HTMLElement;
  const closeBtn   = document.getElementById('cert-modal-close') as HTMLElement;

  function openModal(pdf: string, titulo: string) {
    iframe.src = pdf + '#toolbar=0&navpanes=0&scrollbar=0';
    modalTitle.textContent = titulo;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden'; // evita scroll del fondo
  }

  function closeModal() {
    modal.classList.remove('open');
    iframe.src = ''; // libera el PDF de memoria
    document.body.style.overflow = '';
  }

  // Abrir al hacer click en tarjeta (captura ambos sets via class selector)
  document.querySelectorAll('.cert-card').forEach((card) => {
    card.addEventListener('click', () => {
      const pdf    = (card as HTMLElement).dataset.pdf ?? '';
      const titulo = (card as HTMLElement).dataset.titulo ?? '';
      openModal(pdf, titulo);
    });
  });

  // Cerrar con botón X
  closeBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer click en el backdrop (fuera del box)
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });
</script>
