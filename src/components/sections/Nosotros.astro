---

<section id="nosotros" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="reveal text-center mb-14">
      <p class="text-xs font-medium tracking-widest text-text-muted uppercase mb-3">El estudio</p>
      <h2 class="text-3xl sm:text-4xl font-light text-text">
        Trayectoria y <span class="font-medium">formación</span>
      </h2>
    </div>

    <!-- Foto panorámica de sala de reuniones -->
    <div class="reveal mb-14 overflow-hidden rounded-xl shadow-lg">
      <img
        src="/oficina-reuniones.png"
        alt="Sala de reuniones del estudio — atención a clientes"
        class="w-full h-64 sm:h-80 lg:h-96 object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
    </div>

    <!-- Fix 4: grid con items-start — columna izquierda sticky para no quedar flotando -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

      <!-- Foto — columna izquierda (2/5) — sticky para acompañar el scroll de la derecha -->
      <div class="reveal lg:col-span-2 flex flex-col items-center lg:items-start gap-6 lg:sticky lg:top-28">
        <!-- Foto circular con ring de acento -->
        <div class="relative">
          <div class="w-48 h-48 lg:w-52 lg:h-52 rounded-full ring-4 ring-blue/15 ring-offset-4 ring-offset-cream overflow-hidden shadow-lg">
            <img
              src="/dr-rolando.jpg"
              alt="Rolando Zagret Risco Valera — Fundador y Socio principal"
              loading="lazy"
              class="w-full h-full object-cover object-top scale-110"
            />
          </div>
          <!-- Badge CAL -->
          <div class="absolute -bottom-2 -right-2 bg-blue text-white text-[10px] font-semibold px-2.5 py-1 rounded-full shadow-md">
            CAL N° 35124
          </div>
        </div>

        <!-- Identidad debajo de la foto -->
        <div class="text-center lg:text-left">
          <p class="font-semibold text-text text-base leading-tight">Rolando Zagret<br/>Risco Valera</p>
          <p class="text-sm text-text-muted mt-1.5">Fundador y Socio principal · San Isidro, Lima</p>
        </div>

        <!-- Especialidades: llenan el espacio vacío con info útil -->
        <div class="hidden lg:block w-full">
          <p class="text-[10px] font-medium tracking-widest text-text-muted uppercase mb-3">Áreas de práctica</p>
          <ul class="flex flex-col gap-2">
            {[
              { label: 'Derecho Penal', color: '#2B6CB0' },
              { label: 'Derecho Civil', color: '#3A7D44' },
              { label: 'Derecho Laboral', color: '#E8B84B' },
              { label: 'Derecho Administrativo', color: '#5A6478' },
            ].map((area) => (
              <li class="flex items-center gap-2.5 text-sm text-text-muted">
                <span class="w-1.5 h-1.5 rounded-full flex-none" style={`background:${area.color}`}></span>
                {area.label}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Contenido derecho — columna derecha (3/5) -->
      <div class="lg:col-span-3">

        <p class="reveal text-text-muted leading-relaxed mb-8 text-sm">
          Risco Valera Abogados &amp; Consultores es un estudio jurídico con sede en San Isidro, Lima. Con más de 20 años de ejercicio profesional y más de 15 años bajo la marca MLP, brindamos asesoría legal a personas naturales y empresas con un enfoque directo y orientado a resultados.
        </p>

        <!-- Formación académica — ticker -->
        <div class="reveal reveal-delay-1">
          <!-- Header: label + controles (prev / play-pause / next) -->
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-medium tracking-widest text-text-muted uppercase">Formación académica</p>
            <div class="flex items-center gap-1.5">
              <!-- Flecha anterior — solo desktop -->
              <button id="cert-prev" class="cert-nav-btn hidden sm:flex" aria-label="Anterior" title="Anterior">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="15 18 9 12 15 6"/>
                </svg>
              </button>
              <!-- Play / Pause -->
              <button id="cert-play" class="cert-nav-btn" aria-label="Pausar carrusel" title="Pausar">
                <svg id="cert-icon-pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
                </svg>
                <svg id="cert-icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </button>
              <!-- Flecha siguiente — solo desktop -->
              <button id="cert-next" class="cert-nav-btn hidden sm:flex" aria-label="Siguiente" title="Siguiente">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Fix 2: padding-left en el wrapper para que la primera card no quede bajo el fade -->
          <!-- Ticker wrapper: overflow hidden + mask fade en bordes -->
          <div class="cert-ticker-wrapper">
            <div class="cert-ticker-track" id="cert-track">

              <!-- Set 1: cards reales (accesibles, tabulables) -->
              {credenciales.map((cred) => (
                <button
                  class="cert-card group flex-none w-32 bg-white rounded-lg overflow-hidden shadow-sm border border-black/5 hover:shadow-md transition-shadow duration-200 text-left cursor-pointer"
                  data-pdf={cred.pdf}
                  data-titulo={cred.titulo}
                  title={`${cred.titulo} — ${cred.inst}`}
                >
                  <div class="relative overflow-hidden h-[4.5rem] bg-gray-50">
                    <img
                      src={cred.preview}
                      alt={cred.titulo}
                      class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-2">
                    <p class="text-[10px] font-medium text-text leading-tight line-clamp-2">{cred.titulo}</p>
                    <p class="text-[9px] text-text-muted mt-0.5 leading-tight">{cred.year} · {cred.inst}</p>
                  </div>
                </button>
              ))}

              <!-- Set 2: clones para el loop seamless (aria-hidden, no tabulables) -->
              {credenciales.map((cred) => (
                <button
                  class="cert-card group flex-none w-32 bg-white rounded-lg overflow-hidden shadow-sm border border-black/5 text-left cursor-pointer"
                  data-pdf={cred.pdf}
                  data-titulo={cred.titulo}
                  aria-hidden="true"
                  tabindex="-1"
                >
                  <div class="relative overflow-hidden h-[4.5rem] bg-gray-50">
                    <img
                      src={cred.preview}
                      alt=""
                      class="w-full h-full object-cover object-top"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-2">
                    <p class="text-[10px] font-medium text-text leading-tight line-clamp-2">{cred.titulo}</p>
                    <p class="text-[9px] text-text-muted mt-0.5 leading-tight">{cred.year} · {cred.inst}</p>
                  </div>
                </button>
              ))}

            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Modal PDF viewer -->
<div id="cert-modal" class="cert-modal-backdrop" aria-modal="true" role="dialog" aria-label="Ver certificado">
  <div class="cert-modal-box">
    <!-- Header -->
    <div class="cert-modal-header">
      <p id="cert-modal-title" class="cert-modal-title"></p>
      <button id="cert-modal-close" aria-label="Cerrar" class="cert-modal-close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <!-- iframe PDF -->
    <div class="cert-modal-body">
      <iframe id="cert-modal-iframe" src="" title="Certificado" class="cert-modal-iframe" oncontextmenu="return false;"></iframe>
    </div>
  </div>
</div>

<style>
  /* ── Fix 2: padding-left para que la primera card no quede bajo el fade del mask ── */
  .cert-ticker-wrapper {
    overflow: hidden;
    /* El fade empieza en 10% → la primera card arranca visible */
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    padding-left: 0.5rem;
  }

  /* ── Track: flex en línea, animación CSS pura ── */
  .cert-ticker-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    padding: 0.25rem 0 0.75rem;
    animation: cert-scroll 28s linear infinite;
  }

  /* ── Keyframe: mueve exactamente el 50% (= 1 set de 7 cards) ── */
  @keyframes cert-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Botones de navegación (prev / play-pause / next) — mismo estilo ── */
  .cert-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    background: white;
    color: #5A6478;
    cursor: pointer;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .cert-nav-btn:hover {
    background: #f8f8f6;
    border-color: #2B6CB0;
    color: #2B6CB0;
  }

  /* ── Reduced motion: detiene la animación, oculta los clones ── */
  @media (prefers-reduced-motion: reduce) {
    .cert-ticker-track {
      animation: none;
      flex-wrap: wrap;
      width: auto;
    }
    .cert-card[aria-hidden="true"] {
      display: none;
    }
    .cert-ticker-wrapper {
      mask-image: none;
      -webkit-mask-image: none;
      padding-left: 0;
    }
  }

  /* ── Modal PDF ── */
  .cert-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .cert-modal-backdrop.open {
    display: flex;
  }
  .cert-modal-box {
    background: white;
    border-radius: 12px;
    width: 100%;
    max-width: 860px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.35);
  }
  .cert-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid #e8e6e0;
    flex-shrink: 0;
  }
  .cert-modal-title {
    font-size: 13px;
    font-weight: 500;
    color: #1A1A2E;
  }
  .cert-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #5A6478;
    cursor: pointer;
    transition: background 0.15s;
  }
  .cert-modal-close:hover {
    background: #f3f2ef;
    color: #1A1A2E;
  }
  .cert-modal-body {
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }
  .cert-modal-iframe {
    width: 100%;
    height: 100%;
    min-height: 70vh;
    border: none;
    display: block;
  }
</style>

<script>
  // ── Carrusel: estado compartido ──
  const track     = document.getElementById('cert-track') as HTMLElement;
  const playBtn   = document.getElementById('cert-play') as HTMLButtonElement;
  const prevBtn   = document.getElementById('cert-prev') as HTMLButtonElement;
  const nextBtn   = document.getElementById('cert-next') as HTMLButtonElement;
  const iconPause = document.getElementById('cert-icon-pause') as HTMLElement;
  const iconPlay  = document.getElementById('cert-icon-play') as HTMLElement;

  let paused = false;

  // ── Play / Pause ──
  playBtn?.addEventListener('click', () => {
    paused = !paused;
    track.style.animationPlayState = paused ? 'paused' : 'running';
    iconPause.style.display = paused ? 'none' : '';
    iconPlay.style.display  = paused ? '' : 'none';
    playBtn.setAttribute('aria-label', paused ? 'Reanudar carrusel' : 'Pausar carrusel');
    playBtn.setAttribute('title', paused ? 'Reanudar' : 'Pausar');
  });

  // ── Navegación manual: prev / next ──
  // Estrategia: pausar la animación CSS y manipular scroll del wrapper
  // El wrapper tiene overflow:hidden, el track tiene width:max-content
  // Usamos scrollLeft en el WRAPPER para mover sin romper el loop CSS
  const wrapper = track.parentElement as HTMLElement;

  // Ancho de una card + gap (128px card + 12px gap = 140px)
  const CARD_WIDTH = 140;

  function pauseAutoplay() {
    if (!paused) {
      paused = true;
      // Antes de pausar la animación CSS, capturamos la posición actual
      // para que el scroll manual continúe desde ahí sin saltar
      const computedStyle = getComputedStyle(track);
      const matrix = new DOMMatrix(computedStyle.transform);
      // Aplicamos la posición actual como translateX inline y pausamos
      track.style.transform = `translateX(${matrix.m41}px)`;
      track.style.animation = 'none';
      iconPause.style.display = 'none';
      iconPlay.style.display  = '';
      playBtn.setAttribute('aria-label', 'Reanudar carrusel');
      playBtn.setAttribute('title', 'Reanudar');
    }
  }

  // Al reanudar desde play btn, quitamos el transform inline y restauramos la animación
  playBtn?.addEventListener('click', () => {
    // Si está pausado por nav manual (animation:none), restauramos la animación
    if (track.style.animation === 'none') {
      track.style.transform = '';
      track.style.animation = '';
    }
  }, true); // capture: true para que corra ANTES del listener principal de abajo

  // Offset manual del track (solo cuando está en modo "nav manual")
  let manualOffset = 0;

  prevBtn?.addEventListener('click', () => {
    pauseAutoplay();
    // Si acabamos de pausar, inicializar manualOffset desde la posición actual
    const computedStyle = getComputedStyle(track);
    const matrix = new DOMMatrix(computedStyle.transform);
    manualOffset = matrix.m41;
    // Mover una card hacia la derecha (anterior)
    manualOffset = Math.min(manualOffset + CARD_WIDTH, 0);
    track.style.transform = `translateX(${manualOffset}px)`;
  });

  nextBtn?.addEventListener('click', () => {
    pauseAutoplay();
    const computedStyle = getComputedStyle(track);
    const matrix = new DOMMatrix(computedStyle.transform);
    manualOffset = matrix.m41;
    // Mover una card hacia la izquierda (siguiente)
    // Límite: no ir más allá del 50% del track (= el set clonado)
    const halfTrack = -(track.scrollWidth / 2);
    manualOffset = Math.max(manualOffset - CARD_WIDTH, halfTrack);
    track.style.transform = `translateX(${manualOffset}px)`;
  });

  // ── Fix 1: Modal PDF — URLs ya están pre-encoded en el frontmatter ──
  // data-pdf contiene paths con %XX encoding correcto
  const modal      = document.getElementById('cert-modal') as HTMLElement;
  const iframe     = document.getElementById('cert-modal-iframe') as HTMLIFrameElement;
  const modalTitle = document.getElementById('cert-modal-title') as HTMLElement;
  const closeBtn   = document.getElementById('cert-modal-close') as HTMLElement;

  function openModal(pdf: string, titulo: string) {
    // pdf ya viene con encoding correcto desde data-pdf
    // Solo agregamos los parámetros de visor al fragment
    iframe.src = pdf + '#toolbar=0&navpanes=0&scrollbar=0';
    modalTitle.textContent = titulo;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    iframe.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.cert-card').forEach((card) => {
    card.addEventListener('click', () => {
      const pdf    = (card as HTMLElement).dataset.pdf ?? '';
      const titulo = (card as HTMLElement).dataset.titulo ?? '';
      if (pdf) openModal(pdf, titulo);
    });
  });

  closeBtn?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });
</script>
