---

<section id="nosotros" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="reveal text-center mb-14">
      <p class="text-xs font-medium tracking-widest text-text-muted uppercase mb-3">El estudio</p>
      <h2 class="text-3xl sm:text-4xl font-light text-text">
        Trayectoria y <span class="font-medium">formación</span>
      </h2>
    </div>

    <!-- Foto panorámica de sala de reuniones -->
    <div class="reveal mb-14 overflow-hidden rounded-xl shadow-lg">
      <img
        src="/oficina-reuniones.png"
        alt="Sala de reuniones del estudio — atención a clientes"
        class="w-full h-64 sm:h-80 lg:h-96 object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

      <!-- Foto — columna izquierda (2/5) -->
      <div class="reveal lg:col-span-2 flex flex-col items-center lg:items-start gap-6">
        <!-- Foto circular con ring de acento -->
        <div class="relative">
          <div class="w-48 h-48 lg:w-52 lg:h-52 rounded-full ring-4 ring-blue/15 ring-offset-4 ring-offset-cream overflow-hidden shadow-lg">
            <img
              src="/dr-rolando.jpg"
              alt="Rolando Zagret Risco Valera — Fundador y Socio principal"
              class="w-full h-full object-cover object-top scale-110"
            />
          </div>
          <!-- Badge CAL -->
          <div class="absolute -bottom-2 -right-2 bg-blue text-white text-[10px] font-semibold px-2.5 py-1 rounded-full shadow-md">
            CAL N° 35124
          </div>
        </div>

        <!-- Identidad debajo de la foto -->
        <div class="text-center lg:text-left">
          <p class="font-semibold text-text text-base leading-tight">Rolando Zagret<br/>Risco Valera</p>
          <p class="text-sm text-text-muted mt-1.5">Fundador y Socio principal · San Isidro, Lima</p>
        </div>
      </div>

      <!-- Contenido derecho — columna derecha (3/5) -->
      <div class="lg:col-span-3">

        <p class="reveal text-text-muted leading-relaxed mb-8 text-sm">
          Risco Valera Abogados &amp; Consultores es un estudio jurídico con sede en San Isidro, Lima. Con más de 20 años de ejercicio profesional y más de 15 años bajo la marca MLP, brindamos asesoría legal a personas naturales y empresas con un enfoque directo y orientado a resultados.
        </p>

        <!-- Formación académica — carrusel compacto -->
        <div class="reveal reveal-delay-1">
          <!-- Header con flechas + autoplay -->
          <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-medium tracking-widest text-text-muted uppercase">Formación académica</p>
            <div class="flex gap-1">
              <button id="cert-prev" aria-label="Anterior" class="cert-nav-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button id="cert-play" aria-label="Pausar carrusel" class="cert-nav-btn cert-play-btn" title="Pausar">
                <!-- Ícono pause (estado inicial: playing) -->
                <svg id="cert-icon-pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                <!-- Ícono play (oculto inicialmente) -->
                <svg id="cert-icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </button>
              <button id="cert-next" aria-label="Siguiente" class="cert-nav-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>

          <!-- Scroll horizontal con snap -->
          <div id="cert-scroll" class="flex gap-3 overflow-x-auto pb-3 cert-scroll">
            {credenciales.map((cred) => (
              <button
                class="cert-card group flex-none w-32 bg-white rounded-lg overflow-hidden shadow-sm border border-black/5 hover:shadow-md transition-shadow duration-200 text-left cursor-pointer"
                data-pdf={cred.pdf}
                data-titulo={cred.titulo}
                title={`${cred.titulo} — ${cred.inst}`}
              >
                <!-- Preview imagen -->
                <div class="relative overflow-hidden h-[4.5rem] bg-gray-50">
                  <img
                    src={cred.preview}
                    alt={cred.titulo}
                    class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
                <!-- Info -->
                <div class="p-2">
                  <p class="text-[10px] font-medium text-text leading-tight line-clamp-2">{cred.titulo}</p>
                  <p class="text-[9px] text-text-muted mt-0.5 leading-tight">{cred.year} · {cred.inst}</p>
                </div>
              </button>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Modal PDF viewer -->
<div id="cert-modal" class="cert-modal-backdrop" aria-modal="true" role="dialog" aria-label="Ver certificado">
  <div class="cert-modal-box">
    <!-- Header -->
    <div class="cert-modal-header">
      <p id="cert-modal-title" class="cert-modal-title"></p>
      <button id="cert-modal-close" aria-label="Cerrar" class="cert-modal-close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <!-- iframe PDF -->
    <div class="cert-modal-body">
      <iframe id="cert-modal-iframe" src="" title="Certificado" class="cert-modal-iframe" oncontextmenu="return false;"></iframe>
    </div>
  </div>
</div>

<style>
  .cert-scroll {
    scrollbar-width: thin;
    scrollbar-color: #d1d5db transparent;
    scroll-snap-type: x mandatory;
  }
  .cert-scroll > a {
    scroll-snap-align: start;
  }
  .cert-scroll::-webkit-scrollbar {
    height: 4px;
  }
  .cert-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .cert-scroll::-webkit-scrollbar-thumb {
    background-color: #d1d5db;
    border-radius: 9999px;
  }
  .cert-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    background: white;
    color: #5A6478;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .cert-nav-btn:hover {
    background: #f8f8f6;
    border-color: #2B6CB0;
    color: #2B6CB0;
  }

  /* ── Modal PDF ── */
  .cert-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .cert-modal-backdrop.open {
    display: flex;
  }
  .cert-modal-box {
    background: white;
    border-radius: 12px;
    width: 100%;
    max-width: 860px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0,0,0,0.35);
  }
  .cert-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid #e8e6e0;
    flex-shrink: 0;
  }
  .cert-modal-title {
    font-size: 13px;
    font-weight: 500;
    color: #1A1A2E;
  }
  .cert-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: #5A6478;
    cursor: pointer;
    transition: background 0.15s;
  }
  .cert-modal-close:hover {
    background: #f3f2ef;
    color: #1A1A2E;
  }
  .cert-modal-body {
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }
  .cert-modal-iframe {
    width: 100%;
    height: 100%;
    min-height: 70vh;
    border: none;
    display: block;
  }
</style>

<script>
  // ── Carrusel ──
  const scroll    = document.getElementById('cert-scroll') as HTMLElement;
  const prev      = document.getElementById('cert-prev') as HTMLElement;
  const next      = document.getElementById('cert-next') as HTMLElement;
  const playBtn   = document.getElementById('cert-play') as HTMLElement;
  const iconPause = document.getElementById('cert-icon-pause') as HTMLElement;
  const iconPlay  = document.getElementById('cert-icon-play') as HTMLElement;
  const STEP      = 148;
  const INTERVAL  = 2200; // ms entre cada avance

  let playing = true;
  let timer: ReturnType<typeof setInterval>;

  function advance() {
    if (!scroll) return;
    const maxScroll = scroll.scrollWidth - scroll.clientWidth;
    if (scroll.scrollLeft >= maxScroll - 4) {
      // llegó al final → vuelve al inicio suavemente
      scroll.scrollTo({ left: 0, behavior: 'smooth' });
    } else {
      scroll.scrollBy({ left: STEP, behavior: 'smooth' });
    }
  }

  function startAutoplay() {
    timer = setInterval(advance, INTERVAL);
    playing = true;
    iconPause.style.display = '';
    iconPlay.style.display  = 'none';
    playBtn.setAttribute('aria-label', 'Pausar carrusel');
    playBtn.setAttribute('title', 'Pausar');
  }

  function stopAutoplay() {
    clearInterval(timer);
    playing = false;
    iconPause.style.display = 'none';
    iconPlay.style.display  = '';
    playBtn.setAttribute('aria-label', 'Reanudar carrusel');
    playBtn.setAttribute('title', 'Reanudar');
  }

  // Botón play/pause
  playBtn?.addEventListener('click', () => playing ? stopAutoplay() : startAutoplay());

  // Flechas manuales → pausan el autoplay
  prev?.addEventListener('click', () => {
    stopAutoplay();
    scroll?.scrollBy({ left: -STEP, behavior: 'smooth' });
  });
  next?.addEventListener('click', () => {
    stopAutoplay();
    scroll?.scrollBy({ left: STEP, behavior: 'smooth' });
  });

  // Pausar al pasar el mouse encima
  scroll?.addEventListener('mouseenter', () => { if (playing) stopAutoplay(); });
  scroll?.addEventListener('mouseleave', () => { if (!playing) startAutoplay(); });

  // Arrancar
  startAutoplay();

  // ── Modal PDF ──
  const modal    = document.getElementById('cert-modal') as HTMLElement;
  const iframe   = document.getElementById('cert-modal-iframe') as HTMLIFrameElement;
  const modalTitle = document.getElementById('cert-modal-title') as HTMLElement;
  const closeBtn = document.getElementById('cert-modal-close') as HTMLElement;

  function openModal(pdf: string, titulo: string) {
    iframe.src = pdf + '#toolbar=0&navpanes=0&scrollbar=0';
    modalTitle.textContent = titulo;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden'; // evita scroll del fondo
  }

  function closeModal() {
    modal.classList.remove('open');
    iframe.src = ''; // libera el PDF de memoria
    document.body.style.overflow = '';
  }

  // Abrir al hacer click en tarjeta
  document.querySelectorAll('.cert-card').forEach((card) => {
    card.addEventListener('click', () => {
      const pdf    = (card as HTMLElement).dataset.pdf ?? '';
      const titulo = (card as HTMLElement).dataset.titulo ?? '';
      openModal(pdf, titulo);
    });
  });

  // Cerrar con botón X
  closeBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer click en el backdrop (fuera del box)
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
  });
</script>
