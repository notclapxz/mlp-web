    inst: 'EUCIM Business School',
    year: '2018',
    preview: '/certificados/previews/03-master-gerencia-publica.png',
    pdf: '/certificados/T%C3%ADtulo%20Propio%20Master%20en%20Gerencia%20P%C3%BAblica%20Apostillado.pdf',
