---
const credenciales = [
  {
    id: '01',
    titulo: 'Título de Abogado',
    inst: 'PUCP',
    year: '1997',
    preview: '/certificados/previews/01-titulo-abogado-pucp.png',
    pdf: '/certificados/T%C3%ADtulo%20de%20Abogado%20PUCP%2031.07.2002.pdf',
    color: '#2B6CB0',
  },
  {
    id: '02',
    titulo: 'Maestría en Ciencias Penales',
    inst: 'UNMSM',
    year: '2006',
    preview: '/certificados/previews/02-maestria-derecho-penal.png',
    pdf: '/certificados/Constancia%20de%20Estudios%20de%20Maestr%C3%ADa%20en%20Derecho%20Penal.pdf',
    color: '#1A1A2E',
  },
  {
