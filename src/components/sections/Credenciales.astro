---
const credenciales = [
  {
    id: '01',
    titulo: 'Título de Abogado',
    inst: 'Pontificia Universidad Católica del Perú',
    year: '1997',
    preview: '/certificados/previews/01-titulo-abogado-pucp.png',
    pdf: '/certificados/Título de Abogado PUCP 31.07.2002.pdf',
    color: '#2B6CB0',
  },
  {
    id: '02',
    titulo: 'Maestría en Ciencias Penales',
    inst: 'Universidad Nacional Mayor de San Marcos',
    year: '2006',
    preview: '/certificados/previews/02-maestria-derecho-penal.png',
    pdf: '/certificados/Constancia de Estudios de Maestría en Derecho Penal.pdf',
    color: '#1A1A2E',
  },
  {
    id: '03',
    titulo: 'Master en Gerencia Pública',
    inst: 'EUCIM Business School',
    year: '2018',
    preview: '/certificados/previews/03-master-gerencia-publica.png',
    pdf: '/certificados/Título Propio Master en Gerencia Pública Apostillado.pdf',
    color: '#3A7D44',
  },
  {
    id: '04',
    titulo: 'Máster en Alta Dirección Empresarial',
    inst: 'European Open Business School',
    year: '2021',
    preview: '/certificados/previews/04-master-alta-direccion.png',
    pdf: '/certificados/Máster Alta Dirección Empresarial Universidad de Álcala.pdf',
    color: '#E8B84B',
  },
  {
    id: '05',
    titulo: 'Máster en Política Criminal',
    inst: 'Universidad de Salamanca',
    year: '2025',
    preview: '/certificados/previews/05-master-politica-criminal.png',
    pdf: '/certificados/Diploma Máster en Política Criminal.pdf',
    color: '#2B6CB0',
  },
  {
    id: '06',
    titulo: 'Diploma en Compliance Corporativo',
    inst: 'Instituto para la Calidad — PUCP',
    year: '2021',
    preview: '/certificados/previews/06-diploma-compliance.png',
    pdf: '/certificados/Diploma Compliance Corporativo y Auditoría de Riesgos.pdf',
    color: '#3A7D44',
  },
  {
    id: '07',
    titulo: 'Primer Puesto — Compliance y Auditoría',
    inst: 'Instituto para la Calidad — PUCP',
    year: '2021',
    preview: '/certificados/previews/07-constancia-primer-puesto.png',
    pdf: '/certificados/Constancia Primer Puesto Compliance Corporativo y Auditoría de Riesgos.pdf',
    color: '#E8B84B',
  },
];
---

<section id="credenciales" class="py-20 lg:py-28 bg-surface">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="reveal text-center mb-14">
      <p class="text-xs font-medium tracking-widest text-text-muted uppercase mb-3">Formación académica</p>
      <h2 class="text-3xl sm:text-4xl font-light text-text">
        Credenciales y <span class="font-medium">certificaciones</span>
      </h2>
    </div>

    <!-- Grid de tarjetas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {credenciales.map((cred, i) => (
        <div
          class={`reveal ${i % 2 === 1 ? 'reveal-delay-1' : ''} group relative bg-white rounded-xl overflow-hidden shadow-sm border border-black/5 hover:shadow-md transition-shadow duration-300`}
        >
          <!-- Preview imagen -->
          <a
            href={cred.pdf}
            target="_blank"
            rel="noopener noreferrer"
            class="block relative overflow-hidden bg-gray-50"
            aria-label={`Ver certificado: ${cred.titulo}`}
          >
            <img
              src={cred.preview}
              alt={`Certificado: ${cred.titulo} — ${cred.inst}`}
              class="w-full h-52 object-cover object-top group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <!-- Overlay en hover -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
              <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white text-text text-xs font-medium px-3 py-1.5 rounded-full shadow">
                Ver documento
              </span>
            </div>
            <!-- Número -->
            <div
              class="absolute top-3 left-3 w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold text-white shadow"
              style={`background-color: ${cred.color}`}
            >
              {cred.id}
            </div>
          </a>

          <!-- Info -->
          <div class="p-4">
            <p class="text-sm font-medium text-text leading-snug mb-1">{cred.titulo}</p>
            <p class="text-xs text-text-muted leading-snug mb-3">{cred.inst}</p>
            <div class="flex items-center justify-between">
              <span
                class="text-[10px] font-semibold px-2 py-0.5 rounded-full text-white"
                style={`background-color: ${cred.color}`}
              >
                {cred.year}
              </span>
              <a
                href={cred.pdf}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[11px] text-text-muted hover:text-blue transition-colors duration-200 underline underline-offset-2"
              >
                Ver PDF →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
